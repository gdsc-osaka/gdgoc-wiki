{
  "name": "gdgoc-wiki-discord-bot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "register": "npx tsx scripts/register.ts"
  },
  "dependencies": {
    "discord-hono": "^0.20.3",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@types/node": "^25.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "workerd"],
    "supportedArchitectures": {
      "cpu": ["x64", "arm64"],
      "os": ["darwin", "linux"]
    }
  }
}
