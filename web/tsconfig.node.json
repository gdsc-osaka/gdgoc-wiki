{
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "react-router.config.ts"
  ],
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
