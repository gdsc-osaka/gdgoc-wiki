// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TipTapRenderer golden snapshots > deduplicated headings: same text twice pins the -1 suffix logic 1`] = `"<div class="min-w-0"><h2 id="h-overview" class="text-2xl font-semibold text-gray-900 mb-4 mt-8 border-b border-gray-200 pb-2"><span>Overview</span></h2><p class="mb-4 leading-relaxed text-gray-800"><span>First overview section.</span></p><h2 id="h-overview-1" class="text-2xl font-semibold text-gray-900 mb-4 mt-8 border-b border-gray-200 pb-2"><span>Overview</span></h2><p class="mb-4 leading-relaxed text-gray-800"><span>Second overview section.</span></p></div>"`;

exports[`TipTapRenderer golden snapshots > inline marks: bold, italic, strike, code, link in one paragraph 1`] = `"<div class="min-w-0"><p class="mb-4 leading-relaxed text-gray-800"><span><strong>bold</strong></span><span> </span><span><em>italic</em></span><span> </span><span><s>strike</s></span><span> </span><span><code class="rounded bg-gray-100 px-1 py-0.5 font-mono text-sm">code</code></span><span> </span><span><a href="https://example.com" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">link</a></span></p></div>"`;

exports[`TipTapRenderer golden snapshots > rich article: headings, bold inline, bullet list, code block 1`] = `"<div class="min-w-0"><h1 id="h-getting-started" class="text-3xl font-bold text-gray-900 mb-6 mt-8"><span>Getting Started</span></h1><p class="mb-4 leading-relaxed text-gray-800"><span>Welcome to the </span><span><strong>wiki</strong></span><span>.</span></p><h2 id="h-installation" class="text-2xl font-semibold text-gray-900 mb-4 mt-8 border-b border-gray-200 pb-2"><span>Installation</span></h2><ul class="mb-4 list-disc space-y-1 pl-6"><li><span><span>Clone the repo</span></span></li><li><span><span>Run pnpm install</span></span></li></ul><pre class="mb-4 overflow-x-auto rounded-lg bg-gray-900 p-4"><code class="font-mono text-sm text-gray-100 language-bash">pnpm dev</code></pre></div>"`;

exports[`TipTapRenderer golden snapshots > table: header row and data row 1`] = `"<div class="min-w-0"><div class="mb-4 overflow-x-auto"><table class="w-full border-collapse text-sm"><tbody><tr><th class="border border-gray-300 bg-gray-50 px-3 py-2 text-left font-semibold"><p class="mb-4 leading-relaxed text-gray-800"><span>Name</span></p></th><th class="border border-gray-300 bg-gray-50 px-3 py-2 text-left font-semibold"><p class="mb-4 leading-relaxed text-gray-800"><span>Role</span></p></th></tr><tr><td class="border border-gray-300 px-3 py-2"><p class="mb-4 leading-relaxed text-gray-800"><span>Alice</span></p></td><td class="border border-gray-300 px-3 py-2"><p class="mb-4 leading-relaxed text-gray-800"><span>Lead</span></p></td></tr></tbody></table></div></div>"`;
