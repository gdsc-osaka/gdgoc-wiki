{
  "name": "gdgoc-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "wrangler dev",
    "typecheck": "react-router typegen && tsc && tsc --project tsconfig.node.json",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@react-router/cloudflare": "^7.0.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "better-auth": "^1.5.2",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "i18next": "^25.8.13",
    "marked": "^17.0.3",
    "nanoid": "^5.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-router": "^7.0.0",
    "remix-i18next": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@playwright/test": "^1.50.0",
    "@react-router/dev": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.70.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "supportedArchitectures": {
      "cpu": ["x64", "arm64"],
      "os": ["darwin", "linux"]
    },
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp", "workerd"]
  }
}
