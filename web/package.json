{
  "name": "gdgoc-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "wrangler dev",
    "typecheck": "react-router typegen && tsc && tsc --project tsconfig.node.json",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@playwright/test": "^1.50.0",
    "@react-router/dev": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.109.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "supportedArchitectures": {
      "cpu": ["x64", "arm64"],
      "os": ["darwin", "linux"]
    },
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp", "workerd"]
  }
}
